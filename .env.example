# Shopify Storefront
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Site
NEXT_PUBLIC_SITE_NAME="Oud of Dubai"
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Revalidation (generate a random secret)
SHOPIFY_REVALIDATION_SECRET=your-revalidation-secret

# Customer Auth (from Shopify Admin → Settings → Apps → Develop apps)
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-access-token
SHOPIFY_APPLICATION_ID=your-app-id

# Discount code for combo bundles
COMBO_DISCOUNT_CODE=COMBO10