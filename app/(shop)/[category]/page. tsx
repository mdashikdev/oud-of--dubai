import { getProducts, getCollections } from '@/lib/shopify/queries/products';
import { FeaturedProducts } from '@/components/sections/HomepageSections';
import type { Metadata } from 'next';
import Link from 'next/link';

export async function generateMetadata({ params }: { params: Promise<{ category: string }> }): Promise<Metadata> {
  const { category } = await params;
  const label = category.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
  return { title: label, description: `Shop ${label} fragrances at Oud of Dubai.` };
}

export default async function ShopPage({ params }: { params: Promise<{ category: string }> }) {
  const { category } = await params;
  const [collection, collections] = await Promise.all([getCollection(category), getCollections(20)]);

  if (!collection) {
    return (
      <div className="flex min-h-[50vh] items-center justify-center">
        <div className="text-center space-y-4">
          <h1 className="text-3xl font-bold">Collection Not Found</h1>
          <p className="text-muted-foreground">This collection doesn&apos;t exist yet.</p>
          <Link href="/shop" className="text-primary hover:underline">Browse all products</Link>
        </div>
      </div>
    );
  }

  return (
    <div className="w-full py-12 px-4 sm:px-6 lg:px-8">
      <div className="max-w-7xl mx-auto space-y-12">
        <div className="space-y-2">
          <h1 className="text-3xl md:text-4xl font-bold">{collection.title}</h1>
          {collection.description && (
            <p className="text-muted-foreground text-lg max-w-2xl">{collection.description}</p>
          )}
        </div>
        <FeaturedProducts products={collection.products.nodes} />
      </div>
    </div>
  );
}